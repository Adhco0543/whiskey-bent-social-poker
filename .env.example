# ================================================
# WHISKEY BENT SOCIAL POKER - ENVIRONMENT SETUP
# ================================================
# IMPORTANT: This file serves as a template for local development.
# For production, create a .env file with REAL values and keep it secure.

# Database Configuration (REQUIRED)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/whiskey_bent_dev

# JWT Configuration (REQUIRED - Change this in production!)
# Generate a secure random string for production: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API Server Configuration
PORT=3000
NODE_ENV=development

# Frontend Configuration
# Used by Next.js apps to call the API
NEXT_PUBLIC_API_URL=http://localhost:3000

# Realtime Gateway
REALTIME_PORT=3001

# ================================================
# DEPLOYMENT NOTES
# ================================================
# 1. Generate new JWT_SECRET for each environment
# 2. Use strong database credentials
# 3. Never commit .env file with real secrets
# 4. Use a secrets management system (AWS Secrets Manager, HashiCorp Vault, etc.)
# 5. Ensure DATABASE_URL uses a read-replica for production safety
